# === Account Identity ===
# A friendly name for logging (optional, defaults to filename)
ACCOUNT_NAME=My Account 1

# === Wallet ===
PRIVATE_KEY=0x_your_private_key_here
PROXY_ADDRESS=0x_your_polymarket_proxy_address_here

# WALLET TYPE:
#   SAFE  = Browser Wallet (Metamask, Coinbase Wallet, etc.) — DEFAULT
#   PROXY = Email Sign-In (MagicLink)
WALLET_TYPE=SAFE

# === Authentication Method ===
# Choose ONE: "builder" or "relayer"
AUTH_METHOD=builder

# --- If AUTH_METHOD=builder ---
# Builder API credentials from https://polymarket.com/settings (Builder Profile)
API_KEY=your_builder_api_key
API_SECRET=your_builder_api_secret
API_PASSPHRASE=your_builder_api_passphrase

# --- If AUTH_METHOD=relayer ---
# Relayer API key from https://polymarket.com/settings?tab=api-keys
# Uncomment these and comment out the builder fields above:
# RELAYER_API_KEY=your_relayer_api_key
# RELAYER_API_KEY_ADDRESS=0x_address_that_owns_the_key

# === Optional Per-Account Overrides ===
# These override the shared .env values if set:
# CHAIN_ID=137
# RPC_URL=https://polygon.drpc.org
