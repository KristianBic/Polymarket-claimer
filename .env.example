PRIVATE_KEY=your_private_key_here
# API Credentials from https://polymarket.com/profile (Settings -> API Keys)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
API_PASSPHRASE=your_api_passphrase_here

# Your Polymarket Proxy Address (Found in Profile -> Copy Address)
# This is usually DIFFERENT from your Metamask/EOA address
PROXY_ADDRESS=your_proxy_address_here

# Optional: defaults to Polygon Mainnet (137)
CHAIN_ID=137

# WALLET TYPE CONFIGURATION
# Set to 'SAFE' if you use a Browser Wallet (Metamask, Coinbase Wallet, etc.) - DEFAULT
# Set to 'PROXY' if you use Email Sign-In (MagicLink)
WALLET_TYPE=SAFE
